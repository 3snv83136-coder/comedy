NODE_ENV=development

# URL publique du site (utilisée pour les métadonnées et le sitemap)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Base de données
# - Dev par défaut en SQLite, fichier local ./dev.db
DATABASE_URL="file:./dev.db"
# Pour PostgreSQL en production (exemple) :
# DATABASE_URL="postgresql://user:password@host:5432/biiip?schema=public"

# Choix du provider DB pour Prisma : POSTGRES ou laissé vide pour SQLite
DATABASE_PROVIDER=

# Auth (NextAuth v5)
AUTH_SECRET=change-me-with-a-strong-secret

# Uploads
# UPLOAD_PROVIDER peut être: "local" | "s3" | "cloudinary"
UPLOAD_PROVIDER=local

# S3 compatible (MinIO, Scaleway, etc.)
S3_BUCKET=
S3_REGION=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Optionnel : base publique des URLs (sinon URL S3 classique)
S3_PUBLIC_URL_BASE=

# Cloudinary (si UPLOAD_PROVIDER=cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=biiip-comedy-club

# SMTP (optionnel, pour notifications email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SUBMISSION_NOTIFY_EMAIL=
CONTACT_NOTIFY_EMAIL=

